generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  REQUESTER
  STEWARD
  APPROVER
  ADMIN
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(REQUESTER)
  department   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mdgRequestsCreated  MdgRequest[]  @relation("RequestedBy")
  mdgApprovals        MdgApproval[]
  auditLogs           AuditLog[]

  prRequested  PurchaseRequisition[] @relation("PrRequestedBy")
  prApproved   PurchaseRequisition[] @relation("PrApprovedBy")
  poRequested  PurchaseOrder[]       @relation("PoRequestedBy")
  poApproved   PurchaseOrder[]       @relation("PoApprovedBy")
  grReceived   GoodsReceipt[]        @relation("GrReceivedBy")
  ledgerPosted InventoryLedger[]     @relation("LedgerPostedBy")

  bomsCreated              BillOfMaterials[]   @relation("BomCreatedBy")
  routingsCreated          Routing[]           @relation("RoutingCreatedBy")
  productionOrdersCreated  ProductionOrder[]   @relation("PoCreatedBy")
  productionOrdersReleased ProductionOrder[]   @relation("PoReleasedBy")

  lotConsumptionsPosted    MaterialLotConsumption[] @relation("LotConsumptionPostedBy")
}

enum MasterDataStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  ACTIVE
  INACTIVE
  REJECTED
}

enum MaterialType {
  RAW_MATERIAL
  COMPONENT
  SEMI_FINISHED
  FINISHED_GOOD
  CONSUMABLE
  SPARE_PART
}

model UnitOfMeasure {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  category    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  materials   Material[]

  prLines           PurchaseRequisitionLine[]
  poLines           PurchaseOrderLine[]
  grLines           GoodsReceiptLine[]
  inventoryLedger   InventoryLedger[]
  inventoryBalances InventoryBalance[]

  bomLines                     BillOfMaterialLine[]
  productionOrderHeaderUoms    ProductionOrder[]            @relation("PoUom")
  productionOrderComponentUoms ProductionOrderComponent[]   @relation("PoComponentUom")

  materialLots          MaterialLot[]
  finishedGoodLotUoms   FinishedGoodLot[]            @relation("FgLotUom")
}

model Material {
  id              String           @id @default(cuid())
  materialNumber  String           @unique
  name            String
  description     String?
  type            MaterialType
  status          MasterDataStatus @default(DRAFT)

  unitOfMeasureId String
  unitOfMeasure   UnitOfMeasure    @relation(fields: [unitOfMeasureId], references: [id])
  weightKg        Decimal?         @db.Decimal(12, 4)
  hazardClass     String?
  shelfLifeDays   Int?

  standardCost    Decimal?         @db.Decimal(14, 4)
  leadTimeDays    Int?

  dataQualityScore Int             @default(0)
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  activatedAt      DateTime?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  mdgRequests      MdgRequest[]

  prLines           PurchaseRequisitionLine[]
  poLines           PurchaseOrderLine[]
  grLines           GoodsReceiptLine[]
  inventoryLedger   InventoryLedger[]
  inventoryBalances InventoryBalance[]

  bomsAsParent              BillOfMaterials[]            @relation("BomParent")
  bomLinesAsComponent       BillOfMaterialLine[]         @relation("BomComponent")
  routingsAsParent          Routing[]                    @relation("RoutingParent")
  productionOrdersAsParent  ProductionOrder[]            @relation("PoParent")
  productionOrderComponents ProductionOrderComponent[]   @relation("PoComponentMaterial")

  materialLots     MaterialLot[]
  finishedGoodLots FinishedGoodLot[]     @relation("FgLotMaterial")

  @@index([status])
  @@index([type])
}

model Supplier {
  id               String           @id @default(cuid())
  supplierNumber   String           @unique
  legalName        String
  tradeName        String?
  taxId            String?
  status           MasterDataStatus @default(DRAFT)

  contactEmail     String?
  contactPhone     String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  stateRegion      String?
  postalCode       String?
  country          String?

  paymentTermsDays Int?
  currency         String?
  preferredFlag    Boolean          @default(false)

  dataQualityScore Int              @default(0)
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  activatedAt      DateTime?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  mdgRequests      MdgRequest[]

  purchaseOrders PurchaseOrder[]
  materialLots   MaterialLot[]   @relation("LotSupplier")

  @@index([status])
}

model Customer {
  id               String           @id @default(cuid())
  customerNumber   String           @unique
  legalName        String
  tradeName        String?
  taxId            String?
  status           MasterDataStatus @default(DRAFT)

  contactEmail     String?
  contactPhone     String?
  addressLine1     String?
  city             String?
  country          String?

  creditLimit      Decimal?         @db.Decimal(14, 2)
  paymentTermsDays Int?
  currency         String?

  dataQualityScore Int              @default(0)
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  activatedAt      DateTime?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  mdgRequests      MdgRequest[]

  @@index([status])
}

enum MdgEntityType {
  MATERIAL
  SUPPLIER
  CUSTOMER
  BOM
  ROUTING
  WORK_CENTER
  WAREHOUSE
  UNIT_OF_MEASURE
}

enum MdgRequestType {
  CREATE
  CHANGE
  DEACTIVATE
  REACTIVATE
}

enum MdgRequestStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

model MdgRequest {
  id                    String           @id @default(cuid())
  requestNumber         String           @unique
  entityType            MdgEntityType
  requestType           MdgRequestType
  status                MdgRequestStatus @default(DRAFT)

  payload               Json
  businessJustification String?

  requestedById         String
  requestedBy           User             @relation("RequestedBy", fields: [requestedById], references: [id])
  submittedAt           DateTime?

  completenessScore     Int              @default(0)
  duplicateRiskScore    Int              @default(0)
  validationErrors      Json?

  materialId            String?
  material              Material?        @relation(fields: [materialId], references: [id])
  supplierId            String?
  supplier              Supplier?        @relation(fields: [supplierId], references: [id])
  customerId            String?
  customer              Customer?        @relation(fields: [customerId], references: [id])

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  approvals             MdgApproval[]
  duplicates            MdgDuplicateCandidate[]

  @@index([status])
  @@index([entityType])
}

enum ApprovalDecision {
  PENDING
  APPROVED
  REJECTED
}

model MdgApproval {
  id           String           @id @default(cuid())
  requestId    String
  request      MdgRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approverId   String
  approver     User             @relation(fields: [approverId], references: [id])
  stepOrder    Int
  decision     ApprovalDecision @default(PENDING)
  comments     String?
  decidedAt    DateTime?
  createdAt    DateTime         @default(now())

  @@index([requestId])
  @@index([approverId, decision])
}

model MdgDuplicateCandidate {
  id              String        @id @default(cuid())
  requestId       String
  request         MdgRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  candidateType   MdgEntityType
  candidateId     String
  similarityScore Int
  reasoning       String?
  resolved        Boolean       @default(false)
  resolution      String?
  createdAt       DateTime      @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  actorId     String
  actor       User     @relation(fields: [actorId], references: [id])
  beforeState Json?
  afterState  Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// =========================================================================
// PHASE 2: PROCUREMENT + INVENTORY
// =========================================================================

enum PurchaseRequisitionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CONVERTED_TO_PO
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum GoodsReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum InventoryMovementType {
  GOODS_RECEIPT
  PRODUCTION_RECEIPT
  MATERIAL_ISSUE
  STOCK_TRANSFER
  ADJUSTMENT
  SHIPMENT
}

model Warehouse {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  addressLine1 String?
  city         String?
  country      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storageLocations StorageLocation[]
}

model StorageLocation {
  id          String   @id @default(cuid())
  code        String
  description String?
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  inventoryLedger   InventoryLedger[]
  inventoryBalances InventoryBalance[]
  goodsReceiptLines GoodsReceiptLine[]
  materialLots      MaterialLot[]
  finishedGoodLots  FinishedGoodLot[] @relation("FgLotLocation")

  @@unique([warehouseId, code])
}

model PurchaseRequisition {
  id       String                    @id @default(cuid())
  prNumber String                    @unique
  status   PurchaseRequisitionStatus @default(DRAFT)

  requestedById String
  requestedBy   User    @relation("PrRequestedBy", fields: [requestedById], references: [id])
  department    String?
  reason        String?
  neededBy      DateTime?

  submittedAt     DateTime?
  approvedById    String?
  approvedBy      User?     @relation("PrApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?

  lines       PurchaseRequisitionLine[]
  convertedPo PurchaseOrder?            @relation("PrConvertedToPo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([requestedById])
}

model PurchaseRequisitionLine {
  id         String              @id @default(cuid())
  prId       String
  pr         PurchaseRequisition @relation(fields: [prId], references: [id], onDelete: Cascade)
  lineNumber Int

  materialId      String
  material        Material      @relation(fields: [materialId], references: [id])
  quantity        Decimal       @db.Decimal(14, 4)
  unitOfMeasureId String
  unitOfMeasure   UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])

  estimatedCost Decimal? @db.Decimal(14, 4)
  notes         String?

  createdAt DateTime @default(now())

  @@unique([prId, lineNumber])
}

model PurchaseOrder {
  id       String              @id @default(cuid())
  poNumber String              @unique
  status   PurchaseOrderStatus @default(DRAFT)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  sourcePrId String?              @unique
  sourcePr   PurchaseRequisition? @relation("PrConvertedToPo", fields: [sourcePrId], references: [id])

  requestedById String
  requestedBy   User    @relation("PoRequestedBy", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?   @relation("PoApprovedBy", fields: [approvedById], references: [id])

  submittedAt DateTime?
  approvedAt  DateTime?
  sentAt      DateTime?
  closedAt    DateTime?

  currency    String  @default("USD")
  totalAmount Decimal @default(0) @db.Decimal(16, 4)
  notes       String?

  lines         PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([supplierId])
}

model PurchaseOrderLine {
  id         String        @id @default(cuid())
  poId       String
  po         PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  lineNumber Int

  materialId      String
  material        Material      @relation(fields: [materialId], references: [id])
  quantity        Decimal       @db.Decimal(14, 4)
  unitOfMeasureId String
  unitOfMeasure   UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])
  unitPrice       Decimal       @db.Decimal(14, 4)
  lineTotal       Decimal       @db.Decimal(16, 4)

  quantityReceived Decimal @default(0) @db.Decimal(14, 4)

  notes     String?
  createdAt DateTime @default(now())

  goodsReceiptLines GoodsReceiptLine[]

  @@unique([poId, lineNumber])
}

model GoodsReceipt {
  id       String             @id @default(cuid())
  grNumber String             @unique
  status   GoodsReceiptStatus @default(DRAFT)

  poId String
  po   PurchaseOrder @relation(fields: [poId], references: [id])

  receivedById String
  receivedBy   User      @relation("GrReceivedBy", fields: [receivedById], references: [id])
  receivedAt   DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines GoodsReceiptLine[]

  @@index([status])
  @@index([poId])
}

model GoodsReceiptLine {
  id         String       @id @default(cuid())
  grId       String
  gr         GoodsReceipt @relation(fields: [grId], references: [id], onDelete: Cascade)
  lineNumber Int

  poLineId String
  poLine   PurchaseOrderLine @relation(fields: [poLineId], references: [id])

  materialId String
  material   Material @relation(fields: [materialId], references: [id])

  quantity        Decimal       @db.Decimal(14, 4)
  unitOfMeasureId String
  unitOfMeasure   UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])

  storageLocationId String
  storageLocation   StorageLocation @relation(fields: [storageLocationId], references: [id])

  notes     String?
  createdAt DateTime @default(now())

  @@unique([grId, lineNumber])
}

model InventoryLedger {
  id           String                @id @default(cuid())
  movementType InventoryMovementType

  materialId        String
  material          Material        @relation(fields: [materialId], references: [id])
  storageLocationId String
  storageLocation   StorageLocation @relation(fields: [storageLocationId], references: [id])

  quantity        Decimal       @db.Decimal(14, 4)
  unitOfMeasureId String
  unitOfMeasure   UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])

  referenceType String
  referenceId   String

  postedById String
  postedBy   User     @relation("LedgerPostedBy", fields: [postedById], references: [id])
  postedAt   DateTime @default(now())

  notes String?

  @@index([materialId])
  @@index([storageLocationId])
  @@index([materialId, storageLocationId])
  @@index([referenceType, referenceId])
  @@index([postedAt])
}

model InventoryBalance {
  id String @id @default(cuid())

  materialId        String
  material          Material        @relation(fields: [materialId], references: [id])
  storageLocationId String
  storageLocation   StorageLocation @relation(fields: [storageLocationId], references: [id])

  quantityOnHand  Decimal       @default(0) @db.Decimal(16, 4)
  unitOfMeasureId String
  unitOfMeasure   UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])

  lastMovementAt DateTime?
  updatedAt      DateTime @updatedAt

  @@unique([materialId, storageLocationId])
  @@index([materialId])
  @@index([storageLocationId])
}

// =========================================================================
// PHASE 3: MANUFACTURING (BOM, Routing, Work Center, Production Order)
// =========================================================================

enum BillOfMaterialsStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum RoutingStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ProductionOrderStatus {
  DRAFT
  RELEASED
  IN_PROGRESS
  COMPLETED
  CLOSED
  CANCELLED
}

enum ProductionOperationStatus {
  PENDING
  IN_PROGRESS
  CONFIRMED
  SKIPPED
}

enum WorkCenterType {
  MACHINE
  MANUAL
  ASSEMBLY
  INSPECTION
  PACKAGING
}

model WorkCenter {
  id                   String          @id @default(cuid())
  code                 String          @unique
  name                 String
  description          String?
  type                 WorkCenterType
  capacityHoursPerDay  Decimal?        @db.Decimal(8, 2)
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  routingOperations         RoutingOperation[]
  productionOrderOperations ProductionOrderOperation[]
}

model BillOfMaterials {
  id               String                @id @default(cuid())
  bomNumber        String                @unique
  parentMaterialId String
  parentMaterial   Material              @relation("BomParent", fields: [parentMaterialId], references: [id])
  version          Int                   @default(1)
  status           BillOfMaterialsStatus @default(DRAFT)
  description      String?
  baseQuantity     Decimal               @default(1) @db.Decimal(14, 4)

  createdById      String
  createdBy        User                  @relation("BomCreatedBy", fields: [createdById], references: [id])

  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  lines            BillOfMaterialLine[]
  productionOrders ProductionOrder[]

  @@unique([parentMaterialId, version])
  @@index([parentMaterialId, status])
}

model BillOfMaterialLine {
  id                  String          @id @default(cuid())
  bomId               String
  bom                 BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  lineNumber          Int

  componentMaterialId String
  componentMaterial   Material        @relation("BomComponent", fields: [componentMaterialId], references: [id])
  quantity            Decimal         @db.Decimal(14, 4)
  unitOfMeasureId     String
  unitOfMeasure       UnitOfMeasure   @relation(fields: [unitOfMeasureId], references: [id])
  scrapPercent        Decimal         @default(0) @db.Decimal(5, 2)
  notes               String?

  @@unique([bomId, lineNumber])
}

model Routing {
  id               String        @id @default(cuid())
  routingNumber    String        @unique
  parentMaterialId String
  parentMaterial   Material      @relation("RoutingParent", fields: [parentMaterialId], references: [id])
  version          Int           @default(1)
  status           RoutingStatus @default(DRAFT)
  description      String?

  createdById      String
  createdBy        User          @relation("RoutingCreatedBy", fields: [createdById], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  operations       RoutingOperation[]
  productionOrders ProductionOrder[]

  @@unique([parentMaterialId, version])
  @@index([parentMaterialId, status])
}

model RoutingOperation {
  id                  String     @id @default(cuid())
  routingId           String
  routing             Routing    @relation(fields: [routingId], references: [id], onDelete: Cascade)
  sequence            Int
  description         String
  workCenterId        String
  workCenter          WorkCenter @relation(fields: [workCenterId], references: [id])
  setupTimeHours      Decimal    @default(0) @db.Decimal(8, 2)
  runTimeHoursPerUnit Decimal    @default(0) @db.Decimal(8, 4)
  notes               String?

  @@unique([routingId, sequence])
}

model ProductionOrder {
  id               String                @id @default(cuid())
  orderNumber      String                @unique
  status           ProductionOrderStatus @default(DRAFT)

  parentMaterialId String
  parentMaterial   Material              @relation("PoParent", fields: [parentMaterialId], references: [id])
  quantity         Decimal               @db.Decimal(14, 4)
  unitOfMeasureId  String
  unitOfMeasure    UnitOfMeasure         @relation("PoUom", fields: [unitOfMeasureId], references: [id])

  bomId     String
  bom       BillOfMaterials @relation(fields: [bomId], references: [id])
  routingId String?
  routing   Routing?        @relation(fields: [routingId], references: [id])

  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  releasedAt       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  closedAt         DateTime?

  completedQuantity Decimal @default(0) @db.Decimal(14, 4)
  scrappedQuantity  Decimal @default(0) @db.Decimal(14, 4)

  createdById   String
  createdBy     User    @relation("PoCreatedBy", fields: [createdById], references: [id])
  releasedById  String?
  releasedBy    User?   @relation("PoReleasedBy", fields: [releasedById], references: [id])

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  components       ProductionOrderComponent[]
  operations       ProductionOrderOperation[]
  finishedGoodLots FinishedGoodLot[]

  @@index([status])
  @@index([parentMaterialId])
}

model ProductionOrderComponent {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  lineNumber        Int

  materialId      String
  material        Material      @relation("PoComponentMaterial", fields: [materialId], references: [id])
  unitOfMeasureId String
  unitOfMeasure   UnitOfMeasure @relation("PoComponentUom", fields: [unitOfMeasureId], references: [id])

  plannedQuantity  Decimal @db.Decimal(16, 4)
  issuedQuantity   Decimal @default(0) @db.Decimal(16, 4)
  scrappedQuantity Decimal @default(0) @db.Decimal(16, 4)
  reservedQuantity Decimal @default(0) @db.Decimal(16, 4)

  notes String?

  lotConsumptions MaterialLotConsumption[]

  @@unique([productionOrderId, lineNumber])
  @@index([materialId])
}

model ProductionOrderOperation {
  id                String                    @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder           @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  sequence          Int

  description  String
  workCenterId String
  workCenter   WorkCenter @relation(fields: [workCenterId], references: [id])

  plannedSetupHours Decimal @db.Decimal(8, 2)
  plannedRunHours   Decimal @db.Decimal(10, 4)
  actualSetupHours  Decimal @default(0) @db.Decimal(8, 2)
  actualRunHours    Decimal @default(0) @db.Decimal(10, 4)

  status      ProductionOperationStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?

  @@unique([productionOrderId, sequence])
  @@index([workCenterId, status])
}

// =========================================================================
// PHASE 3 chunk 6: lot tracking + traceability
// =========================================================================

model MaterialLot {
  id                String          @id @default(cuid())
  lotNumber         String          @unique

  materialId        String
  material          Material        @relation(fields: [materialId], references: [id])

  quantityReceived  Decimal         @db.Decimal(16, 4)
  quantityRemaining Decimal         @db.Decimal(16, 4)
  unitOfMeasureId   String
  unitOfMeasure     UnitOfMeasure   @relation(fields: [unitOfMeasureId], references: [id])
  storageLocationId String
  storageLocation   StorageLocation @relation(fields: [storageLocationId], references: [id])

  // Polymorphic provenance
  sourceType        String          // "GoodsReceipt" | "InitialStock"
  sourceRefId       String          // id of the source document
  supplierId        String?
  supplier          Supplier?       @relation("LotSupplier", fields: [supplierId], references: [id])
  receivedAt        DateTime

  notes             String?
  createdAt         DateTime        @default(now())

  consumptions      MaterialLotConsumption[]

  @@index([materialId, quantityRemaining])
  @@index([sourceType, sourceRefId])
  @@index([materialId, storageLocationId, quantityRemaining])
}

model MaterialLotConsumption {
  id                         String                   @id @default(cuid())
  productionOrderComponentId String
  productionOrderComponent   ProductionOrderComponent @relation(fields: [productionOrderComponentId], references: [id], onDelete: Cascade)
  materialLotId              String
  materialLot                MaterialLot              @relation(fields: [materialLotId], references: [id])
  quantity                   Decimal                  @db.Decimal(16, 4)
  postedById                 String
  postedBy                   User                     @relation("LotConsumptionPostedBy", fields: [postedById], references: [id])
  postedAt                   DateTime                 @default(now())
  notes                      String?

  @@index([productionOrderComponentId])
  @@index([materialLotId])
}

model FinishedGoodLot {
  id                String          @id @default(cuid())
  lotNumber         String          @unique

  materialId        String
  material          Material        @relation("FgLotMaterial", fields: [materialId], references: [id])
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id])

  quantity          Decimal         @db.Decimal(16, 4)
  unitOfMeasureId   String
  unitOfMeasure     UnitOfMeasure   @relation("FgLotUom", fields: [unitOfMeasureId], references: [id])
  storageLocationId String
  storageLocation   StorageLocation @relation("FgLotLocation", fields: [storageLocationId], references: [id])

  receivedAt        DateTime        @default(now())
  notes             String?
  createdAt         DateTime        @default(now())

  @@index([productionOrderId])
  @@index([materialId])
}
